# Obrigatória — chave da API Anthropic para tradução e resumo dos artigos
ANTHROPIC_API_KEY=sk-ant-...

# Opcional — modelo Claude para tradução/resumo (padrão: Haiku; sonnet-4-6 para maior qualidade)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Opcional — e-mail para CrossRef polite pool User-Agent (padrão: cardionews@example.com)
CONTACT_EMAIL=seu-email@exemplo.com

# Opcional — porta do servidor Express (padrão: 3000)
PORT=3000

# Opcional — ambiente de execução (development | production)
NODE_ENV=development
