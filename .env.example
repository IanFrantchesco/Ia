# Anthropic API (obrigatório para resumos em português)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Evolution API / WhatsApp
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE=minha-instancia

# Números de WhatsApp para receber o monitor (separados por vírgula, com DDI)
WHATSAPP_NUMBERS=5511999999999,5511888888888

# PubMed API Key (opcional — aumenta o limite de requisições de 3/s para 10/s)
# Obtenha em: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# Máximo de artigos por execução
MAX_ARTICLES=20
